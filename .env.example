# Copy this file to `.env.local` and fill with your own values.
# Both variables are embedded into the client bundle at build time, so
# the publishable key MUST be safe for public use (requires RLS enabled).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
